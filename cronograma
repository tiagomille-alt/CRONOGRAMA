<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Cronograma - Técnico de Enfermagem Meruoca</title>
    <!-- Tailwind CSS para estilização moderna, limpa e responsiva -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons para vetores e símbolos em HD -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="text-slate-800 antialiased min-h-screen flex flex-col">

    <!-- CABEÇALHO -->
    <header class="bg-gradient-to-r from-blue-700 to-indigo-800 text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 py-6 sm:px-6 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="text-center sm:text-left">
                <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight">Cronograma de Estudos</h1>
                <p class="text-blue-100 text-sm mt-1">Técnico de Enfermagem | Prefeitura de Meruoca - CE (Banca: Consulpam)</p>
            </div>
            <div id="statusConexao" class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-xl text-xs font-semibold backdrop-blur-sm">
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-400 animate-pulse" id="dotStatus"></span>
                <span id="textStatus">Sincronizando Banco de Questões...</span>
            </div>
        </div>
    </header>

    <!-- DASHBOARD DE PROGRESSO -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6 w-full">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 bg-white p-5 rounded-2xl shadow-sm border border-slate-100">
            <div class="flex items-center gap-4 border-b sm:border-b-0 sm:border-r border-slate-100 pb-4 sm:pb-0 sm:pr-4">
                <div class="p-3 bg-blue-50 text-blue-600 rounded-xl">
                    <i data-lucide="check-square" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Metas Concluídas</p>
                    <p class="text-2xl font-bold text-slate-800" id="dashMetaPercent">0%</p>
                </div>
            </div>
            <div class="flex items-center gap-4 border-b sm:border-b-0 sm:border-r border-slate-100 py-4 sm:py-0 sm:px-4">
                <div class="p-3 bg-emerald-50 text-emerald-600 rounded-xl">
                    <i data-lucide="award" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Questões Resolvidas</p>
                    <p class="text-2xl font-bold text-slate-800" id="dashResolvidas">0</p>
                </div>
            </div>
            <div class="flex items-center gap-4 pt-4 sm:pt-0 sm:pl-4">
                <div class="p-3 bg-indigo-50 text-indigo-600 rounded-xl">
                    <i data-lucide="percent" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Taxa de Acertos</p>
                    <p class="text-2xl font-bold text-slate-800" id="dashAcerto">0%</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ÁREA DE QUESTÕES INTEGRADA -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6 w-full">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col">
            <!-- Barra de Busca e Filtro -->
            <div class="bg-slate-50 border-b border-slate-100 p-4 flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3">
                <div class="flex-grow">
                    <h3 class="font-bold text-slate-800 flex items-center gap-2 text-sm sm:text-base">
                        <i data-lucide="help-circle" class="text-blue-600 w-5 h-5"></i>
                        QUESTÕES
                    </h3>
                    <p class="text-slate-400 text-[11px] font-medium" id="quizSubtitulo">Digite um assunto abaixo para buscar e carregar as questões correspondentes.</p>
                </div>
                <div class="flex items-center gap-2 w-full sm:w-auto">
                    <div class="relative flex-grow sm:w-64">
                        <input type="text" id="inputFiltroTema" placeholder="Buscar assunto (ex: PNI, SUS, Crase)..." class="w-full bg-white border border-slate-200 rounded-xl pl-3 pr-8 py-2 text-xs font-medium focus:outline-none focus:border-blue-500 transition">
                        <i data-lucide="search" class="w-4 h-4 text-slate-400 absolute right-2.5 top-2.5 pointer-events-none"></i>
                    </div>
                    <button onclick="buscarSimuladoTema(document.getElementById('inputFiltroTema').value)" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold px-4 py-2 rounded-xl shadow-sm shadow-blue-100 transition whitespace-nowrap">
                        Filtrar
                    </button>
                </div>
            </div>

            <!-- Box Dinâmico do Exercício -->
            <div id="containerSimuladoAtivo" class="p-4 sm:p-6 space-y-4">
                <!-- Estado Inicial Neutro -->
                <div id="estadoSimuladoVazio" class="text-center py-8 text-slate-400 space-y-2">
                    <i data-lucide="layout-list" class="w-10 h-10 mx-auto text-slate-300"></i>
                    <p class="text-xs font-semibold">Nenhum tema ativo no momento.</p>
                    <p class="text-[11px]">Digite um assunto ou termo técnico no campo de busca acima para carregar o seu simulado adaptativo.</p>
                </div>

                <!-- Conteúdo Ocultado até Ativação -->
                <div id="estadoSimuladoComDados" class="hidden space-y-4">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-slate-100 pb-3">
                        <h4 class="font-bold text-slate-800 text-sm sm:text-base" id="quizTemaTitulo">Simulado de Estudos</h4>
                        <div class="flex justify-between sm:justify-end items-center bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-100 text-[11px] text-slate-500 font-medium gap-3">
                            <span id="quizQuestaoContador">Questão 1 de 1</span>
                            <span id="quizQuestaoBanca" class="bg-blue-50 text-blue-700 font-bold px-2 py-0.5 rounded text-[10px]">CONCURSO</span>
                        </div>
                    </div>

                    <!-- Enunciado -->
                    <p class="text-xs sm:text-sm font-semibold leading-relaxed text-slate-800" id="quizEnunciado">Carregando pergunta...</p>

                    <!-- Alternativas -->
                    <div class="space-y-2" id="quizAlternativasContainer">
                        <!-- Gerado via JS -->
                    </div>

                    <!-- Explicação -->
                    <div id="quizFeedbackBox" class="hidden p-4 rounded-xl border text-xs sm:text-sm space-y-2">
                        <!-- Revelado após ação de envio -->
                    </div>

                    <!-- Rodapé do Simulado -->
                    <div class="pt-3 border-t border-slate-100 flex justify-between items-center gap-2">
                        <button id="btnPrevQuestao" onclick="prevQuestao()" class="px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition disabled:opacity-40 flex items-center gap-1">
                            <i data-lucide="chevron-left" class="w-4 h-4"></i> Anterior
                        </button>
                        <button id="btnSubmitQuestao" onclick="verificarQuizResposta()" class="px-5 py-2.5 text-xs font-bold text-white bg-blue-600 hover:bg-blue-700 active:bg-blue-800 rounded-xl transition shadow-md shadow-blue-100">
                            Enviar Resposta
                        </button>
                        <button id="btnNextQuestao" onclick="nextQuestao()" class="px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition disabled:opacity-40 flex items-center gap-1">
                            Próxima <i data-lucide="chevron-right" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- GRADE DE PLANEJAMENTO -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full flex-grow">
        <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
            <i data-lucide="calendar" class="text-blue-600"></i> Planilha Semanal de Estudos (9 Semanas)
        </h2>

        <!-- LISTA DE SEMANAS -->
        <div class="space-y-6" id="gradeSemanas">
            <!-- Gerado via JS -->
        </div>
    </main>

    <!-- NOTIFICAÇÃO TOAST -->
    <div id="notificacaoToast" class="fixed bottom-5 right-5 bg-slate-900 text-white px-5 py-3 rounded-xl shadow-lg z-50 flex items-center gap-2 transform translate-y-20 opacity-0 transition-all duration-300 pointer-events-none">
        <i data-lucide="info" class="w-5 h-5 text-blue-400"></i>
        <span class="text-xs font-semibold" id="notificacaoTexto">Mensagem</span>
    </div>

    <footer class="bg-slate-900 text-slate-400 py-6 text-center text-xs mt-auto border-t border-slate-800">
        <p>Cronograma Gerado para uso Pessoal - Foco na Excelência rumo à aprovação em Meruoca-CE.</p>
    </footer>

