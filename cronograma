                    { dia: "Seg", d1: "Vigilância Epidemiológica: Doenças de Notificação Compulsória", d2: "Estudo Reverso: Problemas de Contagem (Análise)", meta: "Diferenciar Notificação Imediata (24 horas) de Notificação Semanal." },
                    { dia: "Ter", d1: "Humanização: Acolhimento com Classificação de Risco", d2: "Estudo Reverso: Probabilidade Básica", meta: "Protocolo de Manchester: Cores, gravidade e tempos de espera." },
                    { dia: "Qua", d1: "REVISÃO FLASH", d2: "Português: Regras de uso do acento de Crase", meta: "Revisão rápida por mapas mentais de Farmacologia e Vacinas." },
                    { dia: "Qui", d1: "SIMULADO DE OURO", d2: "Resolução de uma prova real completa da banca", meta: "Simular tempo de prova, restrição de água e folha de respostas." },
                    { dia: "Sex", d1: "ANÁLISE DE ERROS", d2: "Estudo reverso focado nas falhas do simulado", meta: "Foco em revisar lacunas técnicas de última hora." },
                    { dia: "Sáb", d1: "DESCANSO MENTAL CRUCIAL", d2: "Pausa total para acalmar a ansiedade pré-prova", meta: "Organização de canetas, documentos e rota para o local." },
                    { dia: "Dom", d1: "DIA DA PROVA", d2: "Leitura calma, controle da ansiedade e vitória!", meta: "Foco absoluto." }
                ]
            }
        ];

        window.addEventListener('DOMContentLoaded', () => {
            renderizarGradeSemanal();
            obterQuestoesDoServidor();
            updateDashboard();
            lucide.createIcons();
        });

        function mostrarNotificacao(mensagem, sucesso = true) {
            const toast = document.getElementById('notificacaoToast');
            const texto = document.getElementById('notificacaoTexto');
            texto.innerText = mensagem;
            
            toast.className = `fixed bottom-5 right-5 text-white px-5 py-3 rounded-xl shadow-lg z-50 flex items-center gap-2 transform transition-all duration-300 ${sucesso ? 'bg-slate-900 border-l-4 border-emerald-500' : 'bg-red-900 border-l-4 border-red-500'}`;
            toast.style.opacity = "1";
            toast.style.transform = "translateY(0)";
            
            setTimeout(() => {
                toast.style.opacity = "0";
                toast.style.transform = "translateY(20px)";
            }, 3000);
        }

        async function obterQuestoesDoServidor() {
            try {
                const resposta = await fetch(API_URL);
                if (!resposta.ok) throw new Error("Erro na rede");
                
                BANCO_DE_QUESTOES = await resposta.json();
                
                const dot = document.getElementById('dotStatus');
                const text = document.getElementById('textStatus');
                dot.className = "w-2.5 h-2.5 rounded-full bg-emerald-500";
                text.innerText = "Banco Sincronizado!";
                mostrarNotificacao(`Banco de dados ativo: ${BANCO_DE_QUESTOES.length} questões carregadas!`);
                updateDashboard();
            } catch (erro) {
                console.error(erro);
                const dot = document.getElementById('dotStatus');
                const text = document.getElementById('textStatus');
                dot.className = "w-2.5 h-2.5 rounded-full bg-rose-500";
                text.innerText = "Modo Off-line Ativo";
                mostrarNotificacao("Não foi possível sincronizar o banco. Rodando offline.", false);
            }
        }

        function renderizarGradeSemanal() {
            const container = document.getElementById('gradeSemanas');
            container.innerHTML = '';

            CRONOGRAMA_DADOS.forEach((sem) => {
                let concluidoSemana = 0;
                sem.dias.forEach((d, idx) => {
                    if (progressoGeral[`s${sem.semana}_d${idx}`]) concluidoSemana++;
                });

                const divSemana = document.createElement('div');
                divSemana.className = "bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden";
                divSemana.innerHTML = `
                    <button onclick="toggleSemanaCollapse(${sem.semana})" class="w-full px-4 py-4 sm:px-6 sm:py-5 bg-gradient-to-r from-slate-50 to-slate-100/50 flex justify-between items-center text-left hover:bg-slate-100 transition focus:outline-none">
                        <div>
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="bg-blue-100 text-blue-800 text-[10px] font-bold px-2 py-0.5 rounded-md">SEMANA ${sem.semana}</span>
                                <span class="text-[11px] text-slate-400 font-medium" id="contadorSemana-${sem.semana}">${concluidoSemana} de 7 concluídos</span>
                            </div>
                            <h3 class="text-sm sm:text-base font-bold text-slate-800 mt-1">${sem.titulo}</h3>
                        </div>
                        <i data-lucide="chevron-down" id="iconSemana-${sem.semana}" class="w-5 h-5 text-slate-400 transform transition-transform duration-200 shrink-0"></i>
                    </button>

                    <div id="corpoSemana-${sem.semana}" class="hidden border-t border-slate-100 overflow-x-auto w-full">
                        <div class="inline-block min-w-full align-middle">
                            <table class="min-w-full text-left border-collapse table-fixed sm:table-auto">
                                <thead>
                                    <tr class="bg-slate-50/50 border-b border-slate-100 text-[10px] font-bold uppercase tracking-wider text-slate-400">
                                        <th class="py-3 px-3 w-12 text-center">Feito</th>
                                        <th class="py-3 px-2 w-12">Dia</th>
                                        <th class="py-3 px-3 w-64 sm:w-auto">Disciplina 1 (Enfermagem / Leis)</th>
                                        <th class="py-3 px-3 w-56 sm:w-auto">Disciplina 2 (Gerais / Básicas)</th>
                                        <th class="py-3 px-4 w-48 sm:w-auto">Foco de Questão</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 text-[11px] sm:text-xs" id="tabelaCorpo-${sem.semana}">
                                </tbody>
                            </table>
                        </div>
                    </div>
                `;

                container.appendChild(divSemana);

                const tabelaCorpo = document.getElementById(`tabelaCorpo-${sem.semana}`);
                sem.dias.forEach((d, idx) => {
                    const isChecked = progressoGeral[`s${sem.semana}_d${idx}`] ? 'checked' : '';
                    const tr = document.createElement('tr');
                    tr.className = `hover:bg-slate-50/40 transition ${isChecked ? 'bg-emerald-50/20' : ''}`;
                    tr.innerHTML = `
                        <td class="py-3 px-3 text-center">
                            <input type="checkbox" onchange="toggleProgressoDia(${sem.semana}, ${idx}, this)" ${isChecked} class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500 cursor-pointer transition">
                        </td>
                        <td class="py-3 px-2 font-bold text-slate-500">${d.dia}</td>
                        <td class="py-3 px-3 font-medium text-slate-800 break-words">
                            ${d.dia !== 'Dom' ? `<span>${d.d1}</span>` : `<span class="text-slate-400 italic">${d.d1}</span>`}
                        </td>
                        <td class="py-3 px-3 text-slate-600 break-words">
                            ${d.dia !== 'Dom' ? `<span>${d.d2}</span>` : `<span class="text-slate-400 italic">${d.d2}</span>`}
                        </td>
                        <td class="py-3 px-4 text-slate-500 leading-relaxed font-medium break-words">${d.meta}</td>
                    `;
                    tabelaCorpo.appendChild(tr);
                });
            });

            toggleSemanaCollapse(1);
        }

        function toggleSemanaCollapse(semanaId) {
            const corpo = document.getElementById(`corpoSemana-${semanaId}`);
            const icone = document.getElementById(`iconSemana-${semanaId}`);
            
            if (corpo.classList.contains('hidden')) {
                corpo.classList.remove('hidden');
                icone.style.transform = "rotate(180deg)";
            } else {
                corpo.classList.add('hidden');
                icone.style.transform = "rotate(0deg)";
            }
        }

        function toggleProgressoDia(semana, diaIndex, checkbox) {
            const key = `s${semana}_d${diaIndex}`;
            if (checkbox.checked) {
                progressoGeral[key] = true;
                checkbox.closest('tr').classList.add('bg-emerald-50/20');
            } else {
                delete progressoGeral[key];
                checkbox.closest('tr').classList.remove('bg-emerald-50/20');
            }
            localStorage.setItem('progresso_meruoca', JSON.stringify(progressoGeral));
            updateDashboard();
            atualizarContadorSemana(semana);
        }

        function actualizarContadorSemana(semana) {
            const semData = CRONOGRAMA_DADOS.find(s => s.semana === semana);
            if (!semData) return;
            let concluido = 0;
            semData.dias.forEach((d, idx) => {
                if (progressoGeral[`s${semana}_d${idx}`]) concluido++;
            });
            const el = document.getElementById(`contadorSemana-${semana}`);
            if (el) el.innerText = `${concluido} de 7 concluídos`;
        }

        function updateDashboard() {
            const totalMetas = 9 * 7;
            const concluidas = Object.keys(progressoGeral).length;
            const percentMetas = Math.round((concluidas / totalMetas) * 100) || 0;
            document.getElementById('dashMetaPercent').innerText = `${percentMetas}%`;

            document.getElementById('dashResolvidas').innerText = statsQuiz.solved;
            const taxa = statsQuiz.solved > 0 ? Math.round((statsQuiz.correct / statsQuiz.solved) * 100) : 0;
            document.getElementById('dashAcerto').innerText = `${taxa}%`;
        }

        function normalizarTextoParaTag(texto) {
            return texto.toLowerCase()
                .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
                .replace(/[^a-z0-9\s]/g, "")
                .replace(/\s+/g, "-")
                .trim();
        }

        const STOPWORDS_TAG = new Set(['de','da','do','das','dos','e','em','no','na','nos','nas','para','com','a','o','as','os','ao','aos','um','uma','uns','umas','ou','por']);

        function extrairPalavrasChave(texto) {
            return normalizarTextoParaTag(texto)
                .split('-')
                .filter(palavra => palavra.length > 2 && !STOPWORDS_TAG.has(palavra));
        }

        function pontuarCorrespondencia(palavrasBusca, palavrasQuestao) {
            if (palavrasQuestao.length === 0) return 0;
            let pontos = 0;
            palavrasQuestao.forEach(pq => {
                if (palavrasBusca.includes(pq)) {
                    pontos += 1;
                } else if (palavrasBusca.some(pb => pb.length > 3 && pq.length > 3 && (pb.includes(pq) || pq.includes(pb)))) {
                    pontos += 0.5;
                }
            });
            return pontos / palavrasQuestao.length;
        }

        function buscarSimuladoTema(assuntoOriginal) {
            if (!assuntoOriginal || assuntoOriginal.trim() === "") {
                mostrarNotificacao("Por favor, digite um termo válido para busca.", false);
                return;
            }

            if (BANCO_DE_QUESTOES.length === 0) {
                mostrarNotificacao("Aguarde a sincronização do banco de dados.", false);
                return;
            }

            const tagBusca = normalizarTextoParaTag(assuntoOriginal);
            const palavrasBusca = extrairPalavrasChave(assuntoOriginal);

            activeQuestions = BANCO_DE_QUESTOES.filter(q => normalizarTextoParaTag(q.conteudoTag) === tagBusca);

            if (activeQuestions.length === 0) {
                const candidatos = BANCO_DE_QUESTOES
                    .map(q => ({ q, pontuacao: pontuarCorrespondencia(palavrasBusca, extrairPalavrasChave(q.conteudoTag)) }))
                    .filter(c => c.pontuacao > 0);

                if (candidatos.length > 0) {
                    const melhorPontuacao = Math.max(...candidatos.map(c => c.pontuacao));
                    const limiar = Math.max(melhorPontuacao * 0.6, 0.34);
                    activeQuestions = candidatos.filter(c => c.pontuacao >= limiar).map(c => c.q);
                }
            }

            if (activeQuestions.length === 0) {
                let fallbackTag = "";
                if (assuntoOriginal.toLowerCase().includes("português") || assuntoOriginal.toLowerCase().includes("crase") || assuntoOriginal.toLowerCase().includes("sintaxe") || assuntoOriginal.toLowerCase().includes("regência") || assuntoOriginal.toLowerCase().includes("concordância") || assuntoOriginal.toLowerCase().includes("conjunção") || assuntoOriginal.toLowerCase().includes("ortografia") || assuntoOriginal.toLowerCase().includes("acentuação")) {
                    fallbackTag = "portugues";
                } else if (assuntoOriginal.toLowerCase().includes("sus") || assuntoOriginal.toLowerCase().includes("lei") || assuntoOriginal.toLowerCase().includes("decreto") || assuntoOriginal.toLowerCase().includes("pnab") || assuntoOriginal.toLowerCase().includes("vigilância")) {
                    fallbackTag = "sus";
                } else if (assuntoOriginal.toLowerCase().includes("informática") || assuntoOriginal.toLowerCase().includes("windows") || assuntoOriginal.toLowerCase().includes("excel") || assuntoOriginal.toLowerCase().includes("word") || assuntoOriginal.toLowerCase().includes("segurança")) {
                    fallbackTag = "informatica";
                } else {
                    fallbackTag = "enfermagem";
                }

                activeQuestions = BANCO_DE_QUESTOES.filter(q => {
                    const tagQuestao = normalizarTextoParaTag(q.conteudoTag);
                    return tagQuestao.includes(fallbackTag);
                });
            }

            if (activeQuestions.length === 0) {
                mostrarNotificacao(`Nenhuma questão encontrada para: "${assuntoOriginal}"`, false);
                return;
            }

            currentQuestionIndex = 0;
            document.getElementById('quizTemaTitulo').innerText = assuntoOriginal;
            
            document.getElementById('estadoSimuladoVazio').classList.add('hidden');
            document.getElementById('estadoSimuladoComDados').classList.remove('hidden');
            
            document.getElementById('containerSimuladoAtivo').scrollIntoView({ behavior: 'smooth' });

            renderizarQuestaoQuiz();
        }

        function embaralharArray(array) {
            let copia = [...array];
            for (let i = copia.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [copia[i], copia[j]] = [copia[j], copia[i]];
            }
            return copia;
        }

        function renderizarQuestaoQuiz() {
            const q = activeQuestions[currentQuestionIndex];
            if (!q) return;

            selectedOptionText = null;
            document.getElementById('quizFeedbackBox').className = "hidden";
            document.getElementById('btnSubmitQuestao').disabled = false;

            document.getElementById('quizQuestaoContador').innerText = `Questão ${currentQuestionIndex + 1} de ${activeQuestions.length}`;
            document.getElementById('quizQuestaoBanca').innerText = `${q.banca.toUpperCase()} (${q.ano})`;
            document.getElementById('quizEnunciado').innerText = q.enunciado;

            if (!q.alternativasEmbaralhadas) {
                q.textoRespostaCorreta = resolverRespostaCorreta(q);
                q.alternativasEmbaralhadas = embaralharArray(q.alternativas);
            }

            const container = document.getElementById('quizAlternativasContainer');
            container.innerHTML = '';
            optionButtonsReferencia = [];

            q.alternativasEmbaralhadas.forEach((altText, idx) => {
                const letra = String.fromCharCode(65 + idx);
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-3 border border-slate-200 rounded-xl hover:bg-slate-50 transition text-xs font-semibold text-slate-700 flex items-start gap-2 focus:outline-none";
                btn.onclick = () => selecionarAlternativaSimulado(btn, altText);
                btn.innerHTML = `
                    <span class="w-5 h-5 shrink-0 rounded-full border border-slate-300 bg-white text-[10px] font-bold flex items-center justify-center text-slate-400 mt-0.5" id="badge-${idx}">${letra}</span>
                    <span class="leading-relaxed flex-grow">${altText}</span>
                `;
                container.appendChild(btn);
                optionButtonsReferencia.push({ btn, text: altText, idx });
            });

            if (q.respondidoStatus) {
                restaurarVisualQuestaoRespondida(q);
            } else {
                atualizarNavegadoresQuiz();
            }
        }

        function resolverRespostaCorreta(q) {
            const correta = q.correta;
            if (typeof correta === 'string' && q.alternativas.includes(correta)) {
                return correta;
            }
            if (typeof correta === 'string' && /^[a-zA-Z]$/.test(correta.trim())) {
                const idx = correta.trim().toUpperCase().charCodeAt(0) - 65;
                if (q.alternativas[idx] !== undefined) return q.alternativas[idx];
            }
            const idxNum = parseInt(correta, 10);
            if (!isNaN(idxNum) && q.alternativas[idxNum] !== undefined) {
                return q.alternativas[idxNum];
            }
            return q.alternativas[0];
        }

        function selecionarAlternativaSimulado(botao, textoAlternativa) {
            const q = activeQuestions[currentQuestionIndex];
            if (q.respondidoStatus) return;

            selectedOptionText = textoAlternativa;

            optionButtonsReferencia.forEach(item => {
                item.btn.className = "w-full text-left p-3 border border-slate-200 rounded-xl hover:bg-slate-50 transition text-xs font-semibold text-slate-700 flex items-start gap-2 focus:outline-none";
                const b = document.getElementById(`badge-${item.idx}`);
                b.className = "w-5 h-5 shrink-0 rounded-full border border-slate-300 bg-white text-[10px] font-bold flex items-center justify-center text-slate-400 mt-0.5";
            });

            botao.className = "w-full text-left p-3 border-2 border-blue-600 bg-blue-50/20 rounded-xl transition text-xs font-semibold text-blue-800 flex items-start gap-2 focus:outline-none";
            const currentBadge = botao.querySelector('span');
            currentBadge.className = "w-5 h-5 shrink-0 rounded-full bg-blue-600 text-white text-[10px] font-bold flex items-center justify-center mt-0.5";
        }

        function verificarQuizResposta() {
            const q = activeQuestions[currentQuestionIndex];
            if (!q || !selectedOptionText || q.respondidoStatus) return;

            q.respondidoStatus = true;
            q.alternativaSelecionadaPeloUsuario = selectedOptionText;

            statsQuiz.solved += 1;
            const acerto = (selectedOptionText === q.textoRespostaCorreta);
            if (acerto) {
                statsQuiz.correct += 1;
            }
            localStorage.setItem('stats_meruoca', JSON.stringify(statsQuiz));
            updateDashboard();

            restaurarVisualQuestaoRespondida(q);
        }

        function restaurarVisualQuestaoRespondida(q) {
            document.getElementById('btnSubmitQuestao').disabled = true;

            const feedbackBox = document.getElementById('quizFeedbackBox');
            const acerto = (q.alternativaSelecionadaPeloUsuario === q.textoRespostaCorreta);

            optionButtonsReferencia.forEach(item => {
                item.btn.disabled = true;
                const b = document.getElementById(`badge-${item.idx}`);

                if (item.text === q.textoRespostaCorreta) {
                    item.btn.className = "w-full text-left p-3 border border-emerald-500 bg-emerald-50/30 rounded-xl text-xs font-semibold text-emerald-800 flex items-start gap-2 focus:outline-none";
                    b.className = "w-5 h-5 shrink-0 rounded-full bg-emerald-500 text-white text-[10px] font-bold flex items-center justify-center mt-0.5";
                } else if (item.text === q.alternativaSelecionadaPeloUsuario) {
                    item.btn.className = "w-full text-left p-3 border border-rose-500 bg-rose-50/30 rounded-xl text-xs font-semibold text-rose-800 flex items-start gap-2 focus:outline-none";
                    b.className = "w-5 h-5 shrink-0 rounded-full bg-rose-500 text-white text-[10px] font-bold flex items-center justify-center mt-0.5";
                } else {
                    item.btn.className = "w-full text-left p-3 border border-slate-100 rounded-xl opacity-50 text-xs font-semibold text-slate-400 flex items-start gap-2 focus:outline-none";
                    b.className = "w-5 h-5 shrink-0 rounded-full border border-slate-200 bg-slate-50 text-[10px] font-bold flex items-center justify-center text-slate-300 mt-0.5";
                }
            });

            feedbackBox.className = `p-4 rounded-xl border text-xs sm:text-sm space-y-2 block ${acerto ? 'bg-emerald-50/40 border-emerald-100 text-emerald-900' : 'bg-rose-50/40 border-rose-100 text-rose-900'}`;
            feedbackBox.innerHTML = `
                <div class="flex items-center gap-1.5 font-bold">
                    <i data-lucide="${acerto ? 'check-circle' : 'alert-circle'}" class="w-4 h-4 text-${acerto ? 'emerald' : 'rose'}-600"></i>
                    ${acerto ? 'Parabéns, você acertou!' : 'Você errou esta questão.'}
                </div>
                <div class="text-[11px] text-slate-600 mt-1">
                    <strong>Gabarito Oficial:</strong> ${q.textoRespostaCorreta}
                </div>
                <div class="text-[11px] text-slate-700 bg-white/70 p-3 rounded-lg border border-slate-100 leading-relaxed mt-2">
                    <strong>Explicação:</strong> ${q.explicacao}
                </div>
            `;

            atualizarNavegadoresQuiz();
            lucide.createIcons();
        }

        function atualizarNavegadoresQuiz() {
            document.getElementById('btnPrevQuestao').disabled = (currentQuestionIndex === 0);
            document.getElementById('btnNextQuestao').disabled = (currentQuestionIndex === activeQuestions.length - 1);
        }

        function nextQuestao() {
            if (currentQuestionIndex < activeQuestions.length - 1) {
                currentQuestionIndex++;
                renderizarQuestaoQuiz();
            }
        }

        function prevQuestao() {
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                renderizarQuestaoQuiz();
            }
        }
    </script>
